{
  "name": "activant-yc-scout",
  "version": "0.1.0",
  "private": true,
  "description": "Monitors new Y Combinator batches, scores companies against Activant's two evaluation criteria, and answers questions about any YC company or batch.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "ingest": "tsx scripts/ingest-batch.ts",
    "score": "tsx scripts/score-batch.ts",
    "pipeline": "tsx scripts/run-pipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "next": "^15.5.4",
    "openai": "^6.45.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "jsdom": "^29.1.1",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
