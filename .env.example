# Copy this file to .env, fill in real values, and never commit .env itself.
# Also worth knowing: Supabase gives you three different connection string
# variants (Direct connection, Session pooler, Transaction pooler). The
# Direct one is IPv6-only on the free tier and won't work from Vercel or a
# GitHub Codespace — use a pooler string for both DATABASE_URL below and
# any one-off commands (npx prisma db push, running scripts by hand).

# Postgres connection string. Works with any Postgres host; Supabase and
# Neon both give you this in their dashboard as soon as you create a project.
# Example (Supabase, Session pooler — use this one, not Direct connection):
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/yc_scout"

# Used for: founder extraction, triage + deep-dive scoring, and the chat
# endpoint — all routed through OpenRouter (https://openrouter.ai/api/v1),
# not Anthropic directly. See docs/ARCHITECTURE.md#model-provider for why.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Optional overrides if OpenRouter's slug for a given Claude version
# changes — check https://openrouter.ai/models if a request 404s on
# "model not found." Defaults live in src/lib/ai/openrouter.ts.
# OPENROUTER_SCORING_MODEL="anthropic/claude-sonnet-5"
# OPENROUTER_EXTRACTION_MODEL="anthropic/claude-haiku-4.5"
# OPENROUTER_CHAT_MODEL="anthropic/claude-sonnet-5"

# Optional — only needed if the (currently inactive) Activant Research MCP
# thesis provider is ever activated. That's the one piece of this codebase
# still on the direct Anthropic API (an Anthropic-only beta feature with no
# OpenRouter equivalent) — see src/lib/thesis/mcpProvider.ts. Leave both
# blank to keep using the manual-docs fallback (the current default).
# ANTHROPIC_API_KEY="sk-ant-..."
# ACTIVANT_RESEARCH_MCP_URL="https://activant-research.fastmcp.app/mcp"
# ACTIVANT_RESEARCH_MCP_TOKEN=""
